{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,

    "moduleResolution": "NodeNext",
    "types": ["node"],
    "ignoreDeprecations": "6.0"
  },

  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}